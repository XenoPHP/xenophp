{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "npm run build && concurrently --kill-others --raw \"php xeno serve --internal-process\" \"vite\" \"php xeno socket:serve start\"",
        "socket": "php xeno socket:serve start",
        "start": "npm run dev",
        "vite": "vite"
    },
    "devDependencies": {
        "axios": "^1.11.0",
        "concurrently": "^9.2.1",
        "laravel-vite-plugin": "^2.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3"
    }
}
